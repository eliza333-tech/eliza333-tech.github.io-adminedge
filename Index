  const ptbody=document.getElementById('amd-payout-tbody');
  ptbody.innerHTML='';
  if(a.payouts.length===0){
    ptbody.innerHTML='<tr><td colspan="6" style="padding:16px 18px;color:var(--g600);font-size:9px;letter-spacing:1px;">// NO PAYOUTS YET</td></tr>';
  } else {
    a.payouts.forEach((p,i)=>{
      const tr=document.createElement('tr');
      tr.innerHTML=`
        <td style="color:var(--g600);font-size:9px;">${String(i+1).padStart(2,'0')}</td>
        <td style="color:var(--g400);">${p.date}</td>
        <td><span class="pay-amt">${p.amount}</span></td>
        <td style="color:var(--g400);">${p.note}</td>
        <td><span class="${p.status==='paid'?'ps-paid':'ps-pending'}">${p.status.toUpperCase()}</span></td>
        <td style="color:var(--g600);font-size:9px;">${p.method}</td>`;
      ptbody.appendChild(tr);
    });
  }
  const totalPaidOut=a.payouts.reduce((s,p)=>s+parseFloat(p.amount.replace('$','')),0);
  document.getElementById('amd-payout-total').textContent='TOTAL PAID OUT: $'+totalPaidOut.toFixed(2);
  document.getElementById('amd-notes').textContent=a.notes||'—';
}

function closeAmbDetail(){
  document.getElementById('amb-detail-view').style.display='none';
  document.getElementById('amb-list-view').style.display='flex';
  selectedAmb=null;
}

function openAddAmb(){
  document.getElementById('amb-add-panel').style.display='flex';
}
function closeAddAmb(){
  document.getElementById('amb-add-panel').style.display='none';
}

function saveNewAmb(){
  const name=document.getElementById('anew-name').value.trim();
  const email=document.getElementById('anew-email').value.trim();
  const code=document.getElementById('anew-code').value.trim().toUpperCase();
  const theirCut=parseInt(document.getElementById('anew-their-cut').value)||0;
  const userDisc=parseInt(document.getElementById('anew-user-disc').value)||0;
  const notes=document.getElementById('anew-notes').value.trim();
  if(!name||!email||!code){return;}
  const newAmb={
    id:'AMB-00'+Math.floor(Math.random()*900+100),
    name,email,code,
    broughtOn:'Apr 10, 2026',broughtTs:20260410,
    active:true,theirCut,userDisc,
    totalRevenue:0,initialRev:0,recurringRev:0,
    commissionEarned:0,paidOut:0,
    referrals:[],payouts:[],notes
  };
  AMBASSADORS.unshift(newAmb);
  renderAmbTable();
  document.getElementById('anew-name').value='';
  document.getElementById('anew-email').value='';
  document.getElementById('anew-code').value='';
  document.getElementById('anew-their-cut').value='';
  document.getElementById('anew-user-disc').value='';
  document.getElementById('anew-notes').value='';
  const t=document.getElementById('anew-toast');
  t.style.display='block';
  setTimeout(()=>{t.style.display='none';closeAddAmb();},1800);
}

init();renderAmbTable();
</script>
