let currentFilter='all',sortKey='name',sortAsc=true,selectedUser=null;

function init(){renderTable();updateSummary();updateNav();}

function updateNav(){
  const a=USERS.filter(u=>u.active).length;
  const m=USERS.reduce((s,u)=>s+u.mrr,0);
  document.getElementById('nav-active').textContent=a;
  document.getElementById('nav-mrr').textContent='$'+m.toLocaleString()+'/mo';
}

function renderSidebar(){renderTable();}

function getFiltered(){
  const q=document.getElementById('search-input').value.toLowerCase();
  let data=[...USERS];
  if(q) data=data.filter(u=>u.name.toLowerCase().includes(q)||u.email.toLowerCase().includes(q)||u.id.toLowerCase().includes(q));
  if(currentFilter==='active') data=data.filter(u=>u.active);
  if(currentFilter==='inactive') data=data.filter(u=>!u.active);
  if(currentFilter==='pending') data=data.filter(u=>u.contractShort==='PENDING');
  data.sort((a,b)=>{
    let av=a[sortKey],bv=b[sortKey];
    if(typeof av==='string'){av=av.toLowerCase();bv=bv.toLowerCase();}
    return sortAsc?(av<bv?-1:av>bv?1:0):(av>bv?-1:av<bv?1:0);
  });
  return data;
}

function renderTable(){
  const data=getFiltered();
  const tbody=document.getElementById('table-body');
  tbody.innerHTML='';
  data.forEach(u=>{
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td class="nm cw-name">${u.name}</td>
      <td class="cw-status"><span class="pill ${u.active?'active':'inactive'}">${u.active?'ACTIVE':'INACTIVE'}</span></td>
      <td class="cw-plan" style="color:var(--g400);">${u.planShort}</td>
      <td class="cw-joined mt">${u.signup}</td>
      <td class="cw-subend mt">${u.tlEnd}</td>
      <td class="cw-last" style="color:${u.lastSignTs>=20260408?'var(--green)':'var(--g400)'}">${u.lastSign}</td>
      <td class="cw-paid grn">${u.paid}</td>
      <td class="cw-units ${u.unitsNum>0?'grn':'rd'}">${u.unitsUp}</td>
      <td class="cw-logged" style="color:var(--g400);">${u.logged}</td>
      <td class="cw-wr" style="color:${u.winrateNum>=60?'var(--green)':u.winrateNum>=55?'#fff':'var(--red)'}">${u.winrate}</td>
      <td class="cw-sport mt">${u.sport}</td>
      <td class="cw-contract"><span class="pill ${u.contractShort==='SIGNED'?'signed':'pending'}">${u.contractShort}</span></td>
      <td class="cw-email mt">${u.email}</td>
      <td class="cw-id mt">${u.id}</td>`;
    tr.onclick=()=>selectUser(u);
    tbody.appendChild(tr);
  });
}

function updateSummary(){
  const data=getFiltered();
  const active=data.filter(u=>u.active).length;
  const totalPaid=data.reduce((s,u)=>s+u.paidNum,0);
  const avgWr=data.length?Math.round(data.reduce((s,u)=>s+u.winrateNum,0)/data.length):0;
  const totalU=data.reduce((s,u)=>s+u.unitsNum,0).toFixed(1);
  const mrr=data.reduce((s,u)=>s+u.mrr,0);
  document.getElementById('sum-total').textContent=data.length;
  document.getElementById('sum-active').textContent=active;
  document.getElementById('sum-paid').textContent='$'+totalPaid.toLocaleString();
  document.getElementById('sum-wr').textContent=avgWr+'%';
  document.getElementById('sum-units').textContent='+'+totalU+'u';
  document.getElementById('sum-mrr').textContent='$'+mrr.toLocaleString()+'/mo';
}

function setFilter(f,btn){
  currentFilter=f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('filter-lbl').textContent=f.toUpperCase();
  renderTable();updateSummary();
}

function sortBy(key){
  if(sortKey===key) sortAsc=!sortAsc; else{sortKey=key;sortAsc=true;}
  document.querySelectorAll('[id^="arr-"]').forEach(el=>el.textContent='');
  const a=document.getElementById('arr-'+key);
  if(a) a.textContent=sortAsc?'▼':'▲';
  renderTable();
}

