  document.getElementById('view-empty').classList.remove('show');
  ['tab-all','tab-create','tab-ambassador'].forEach(id=>document.getElementById(id).classList.remove('active'));

  if(view==='all'){
    document.getElementById('view-all').style.display='flex';
    document.getElementById('tab-all').classList.add('active');
  } else if(view==='user'&&selectedUser){
    document.getElementById('view-user').style.display='flex';
  } else if(view==='create'){
    document.getElementById('view-create').style.display='flex';
    document.getElementById('tab-create').classList.add('active');
  } else if(view==='ambassador'){
    const av=document.getElementById('view-ambassador');
    av.style.display='flex';
    av.style.flexDirection='column';
    document.getElementById('tab-ambassador').classList.add('active');
  } else {
    document.getElementById('view-empty').classList.add('show');
  }
}

