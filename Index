<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edge Terminal — Admin Console</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --black:#000000;--white:#ffffff;
  --g100:#f5f5f5;--g200:#e0e0e0;--g400:#888888;--g600:#555555;--g800:#333333;
  --g900:#1a1a1a;--g950:#0a0a0a;
  --green:#00ff88;--green-dim:#00cc6a;--green-dark:#003322;
  --red:#ff3344;--red-dim:#cc2233;
  --surface:#0a0a0a;--surface2:#111111;--border:#1a1a1a;--border2:#2a2a2a;
  --mono:'Space Mono','Courier New',monospace;
}
html,body{height:100%;overflow:hidden;}
body{background:#000;color:#fff;font-family:var(--mono);font-size:12px;line-height:1.5;}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.018) 2px,rgba(0,0,0,0.018) 4px);pointer-events:none;z-index:9999;}

.nav{height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:rgba(0,0,0,0.97);border-bottom:1px solid var(--border);position:fixed;top:0;left:0;right:0;z-index:100;}
.nav-brand{font-size:12px;font-weight:700;letter-spacing:3px;color:#fff;white-space:nowrap;}
.nav-brand span{color:var(--g600);font-weight:400;}
.nav-center{display:flex;gap:0;}
.nav-tab{padding:0 20px;height:48px;display:flex;align-items:center;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);cursor:pointer;border-bottom:2px solid transparent;border-right:1px solid var(--border);transition:all 0.15s;user-select:none;white-space:nowrap;}
.nav-tab:first-child{border-left:1px solid var(--border);}
.nav-tab:hover{color:#fff;}
.nav-tab.active{color:#fff;border-bottom-color:transparent;border-left:2px solid #fff;padding-left:14px;}
.nav-tab.create-tab.active{color:var(--green);border-left-color:var(--green);border-bottom-color:transparent;}
.nav-right{display:flex;align-items:center;gap:16px;}
.nav-stat{text-align:right;}
.nav-stat-val{font-size:12px;font-weight:700;color:var(--green);}
.nav-stat-label{font-size:8px;letter-spacing:1.5px;color:var(--g600);text-transform:uppercase;}
.nav-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.3;}}

.app{display:grid;grid-template-columns:200px 1fr;height:calc(100vh - 48px);margin-top:48px;overflow:hidden;}
.sidebar{background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;}
.main{display:flex;flex-direction:column;overflow:hidden;}

.sid-search{padding:12px;border-bottom:1px solid var(--border);}
.sid-search input{width:100%;background:var(--border);border:1px solid var(--border2);color:#fff;font-family:var(--mono);font-size:10px;padding:7px 10px;outline:none;}
.sid-search input::placeholder{color:var(--g600);}
.sid-search input:focus{border-color:var(--g600);}
.sid-colhdr{display:grid;grid-template-columns:1fr auto;padding:7px 12px;border-bottom:1px solid var(--border);font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);background:var(--surface2);}
.sid-list{flex:1;overflow-y:auto;}
.sid-list::-webkit-scrollbar{width:3px;}
.sid-list::-webkit-scrollbar-thumb{background:var(--border2);}
.sid-user{padding:10px 12px;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;}
.sid-user:hover{background:var(--border);}
.sid-user.active{background:var(--border2);border-left:2px solid var(--green);padding-left:10px;}
.sid-name{font-size:11px;font-weight:700;color:#fff;margin-bottom:1px;}
.sid-id{font-size:9px;color:var(--g600);}
.sid-row{display:flex;align-items:center;justify-content:space-between;margin-top:5px;}
.dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.dot-green{background:var(--green);}
.dot-gray{background:var(--g600);}
.dot-red{background:var(--red);}
.sid-status{display:flex;align-items:center;gap:5px;font-size:8px;letter-spacing:1px;text-transform:uppercase;}
.sid-units{font-size:10px;font-weight:700;}

#view-all{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.tbl-topbar{padding:12px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface);flex-shrink:0;}
.tbl-filters{display:flex;gap:8px;}
.filter-btn{font-family:var(--mono);font-size:8px;letter-spacing:1.5px;text-transform:uppercase;padding:5px 12px;background:transparent;color:var(--g600);border:1px solid var(--border2);cursor:pointer;transition:all 0.1s;}
.filter-btn:hover{color:#fff;border-color:var(--g400);}
.filter-btn.active{color:#fff;border-color:#fff;background:var(--border2);}
.tbl-wrap{flex:1;overflow:auto;}
.tbl-wrap::-webkit-scrollbar{height:3px;width:3px;}
.tbl-wrap::-webkit-scrollbar-thumb{background:var(--border2);}
table.dt{width:100%;border-collapse:collapse;table-layout:fixed;}
table.dt thead{position:sticky;top:0;z-index:10;}
table.dt th{background:var(--surface2);padding:8px 14px;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);text-align:left;border-bottom:1px solid var(--border);font-weight:400;white-space:nowrap;cursor:pointer;user-select:none;border-right:1px solid var(--border);}
table.dt th:hover{color:#fff;}
table.dt td{padding:0 14px;height:44px;font-size:10px;color:var(--g400);border-bottom:1px solid var(--border);vertical-align:middle;border-right:1px solid var(--border);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
table.dt tr:hover td{background:rgba(255,255,255,0.018);cursor:pointer;}
table.dt td.nm{color:#fff;font-weight:700;font-size:11px;}
table.dt td.grn{color:var(--green);font-weight:700;}
table.dt td.rd{color:var(--red);font-weight:700;}
table.dt td.mt{color:var(--g600);}
.pill{display:inline-block;font-size:8px;letter-spacing:1px;text-transform:uppercase;padding:2px 8px;border:1px solid;}
.pill.active{color:var(--green);border-color:rgba(0,255,136,0.3);}
.pill.inactive{color:var(--red);border-color:rgba(255,51,68,0.3);}
.pill.signed{color:var(--green);border-color:rgba(0,255,136,0.2);}
.pill.pending{color:var(--red);border-color:rgba(255,51,68,0.2);}
.tbl-footer{padding:10px 20px;border-top:1px solid var(--border);display:grid;grid-template-columns:repeat(6,1fr);background:var(--surface);flex-shrink:0;}
.sum-cell{padding:8px 16px;border-right:1px solid var(--border);}
.sum-cell:first-child{padding-left:0;}
.sum-cell:last-child{border-right:none;}
.sum-label{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);margin-bottom:3px;}
.sum-val{font-size:14px;font-weight:700;color:#fff;}
.sum-val.grn{color:var(--green);}

#view-user{flex:1;overflow-y:auto;display:none;flex-direction:column;}
#view-user::-webkit-scrollbar{width:3px;}
#view-user::-webkit-scrollbar-thumb{background:var(--border2);}
.detail-topbar{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface);position:sticky;top:0;z-index:10;}
.crumb{font-size:8px;letter-spacing:1.5px;color:var(--g600);text-transform:uppercase;cursor:pointer;margin-bottom:2px;}
.crumb:hover{color:#fff;}
.detail-name{font-size:15px;font-weight:700;color:#fff;}
.badges{display:flex;gap:8px;}
.dbadge{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 10px;border:1px solid;}
.dbadge.active{color:var(--green);border-color:rgba(0,255,136,0.3);}
.dbadge.inactive{color:var(--red);border-color:rgba(255,51,68,0.3);}
.dbadge.neutral{color:var(--g400);border-color:var(--border2);}

.metrics-strip{display:grid;grid-template-columns:repeat(5,1fr);border-bottom:1px solid var(--border);flex-shrink:0;}
.mc{padding:16px 18px;border-right:1px solid var(--border);}
.mc:last-child{border-right:none;}
.mc-label{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);margin-bottom:6px;}
.mc-val{font-size:22px;font-weight:700;line-height:1;color:#fff;}
.mc-val.grn{color:var(--green);}
.mc-sub{font-size:9px;color:var(--g600);margin-top:4px;}

.two-col{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--border);}
.panel{border-right:1px solid var(--border);}
.panel:last-child{border-right:none;}
.panel-hdr{padding:8px 18px;background:var(--surface2);border-bottom:1px solid var(--border);font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);}
.ir{display:grid;grid-template-columns:150px 1fr;border-bottom:1px solid var(--border);align-items:center;min-height:34px;}
.ir:last-child{border-bottom:none;}
.ik{padding:8px 18px;font-size:9px;color:var(--g600);}
.iv{padding:8px 18px 8px 0;font-size:10px;color:#fff;font-weight:700;}
.iv.grn{color:var(--green);}
.iv.gray{color:var(--g400);font-weight:400;}
.iv.rd{color:var(--red);}

.tl-wrap{padding:16px 18px;}
.tl-labels{display:flex;justify-content:space-between;font-size:9px;color:var(--g600);margin-bottom:6px;}
.tl-bar{width:100%;height:5px;background:var(--border2);}
.tl-fill{height:100%;background:var(--green);transition:width 0.4s;}
.tl-meta{display:flex;justify-content:space-between;font-size:9px;color:var(--g600);margin-top:5px;}
.tl-events{margin-top:16px;border-top:1px solid var(--border);padding-top:12px;}
.tl-event{display:flex;align-items:flex-start;gap:10px;padding:7px 0;border-bottom:1px solid var(--border);}
.tl-event:last-child{border-bottom:none;}
.tl-evt-txt{flex:1;font-size:9px;color:var(--g400);line-height:1.4;}
.tl-evt-date{font-size:9px;color:var(--g600);}

.pay-section{border-bottom:1px solid var(--border);}
.pay-hdr{padding:8px 18px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.pay-hdr-txt{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);}
.pay-hdr-total{font-size:10px;font-weight:700;color:var(--green);}
table.pay-table{width:100%;border-collapse:collapse;}
table.pay-table th{padding:7px 18px;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);text-align:left;background:var(--surface);border-bottom:1px solid var(--border);font-weight:400;white-space:nowrap;border-right:1px solid var(--border);}
table.pay-table th:last-child{border-right:none;}
table.pay-table td{padding:0 18px;height:38px;font-size:10px;color:var(--g400);border-bottom:1px solid var(--border);vertical-align:middle;border-right:1px solid var(--border);}
table.pay-table td:last-child{border-right:none;}
table.pay-table tr:last-child td{border-bottom:none;}
.pay-amt{color:#fff;font-weight:700;}
.ps-paid{color:var(--green);font-size:8px;letter-spacing:1px;text-transform:uppercase;border:1px solid rgba(0,255,136,0.3);padding:2px 7px;}
.ps-pending{color:var(--g600);font-size:8px;letter-spacing:1px;text-transform:uppercase;border:1px solid var(--border2);padding:2px 7px;}
.ps-failed{color:var(--red);font-size:8px;letter-spacing:1px;text-transform:uppercase;border:1px solid rgba(255,51,68,0.3);padding:2px 7px;}

.three-col{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid var(--border);}
.sms{padding:14px 18px;border-right:1px solid var(--border);}
.sms:last-child{border-right:none;}
.sms-label{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);margin-bottom:5px;}
.sms-val{font-size:18px;font-weight:700;color:#fff;}
.sms-val.grn{color:var(--green);}

.notes-section{border-bottom:1px solid var(--border);}
.notes-body{padding:14px 18px;font-size:10px;color:var(--g400);line-height:1.8;}

#view-create{flex:1;overflow-y:auto;display:none;}
.create-wrap{padding:40px;max-width:660px;}
.create-eyebrow{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);margin-bottom:4px;}
.create-heading{font-size:22px;font-weight:700;color:#fff;margin-bottom:32px;}
.create-section-title{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;}
.fg{display:flex;flex-direction:column;gap:6px;}
.form-label{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--g600);}
.form-input{background:var(--border);border:1px solid var(--border2);color:#fff;font-family:var(--mono);font-size:11px;padding:9px 13px;outline:none;width:100%;}
.form-input::placeholder{color:var(--g600);}
.form-input:focus{border-color:var(--g400);}
.form-select{background:var(--border);border:1px solid var(--border2);color:#fff;font-family:var(--mono);font-size:11px;padding:9px 13px;outline:none;appearance:none;width:100%;}
.create-btn{background:var(--green);color:#000;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:11px 28px;border:none;cursor:pointer;transition:background 0.1s;}
.create-btn:hover{background:var(--green-dim);}
.create-btn:active{transform:scale(0.98);}
.create-hint{font-size:9px;color:var(--g600);margin-top:12px;line-height:1.7;}
.toast-bar{display:none;margin-top:16px;padding:12px 16px;border:1px solid rgba(0,255,136,0.3);background:rgba(0,255,136,0.04);font-size:10px;color:var(--green);letter-spacing:1px;}

#view-empty{flex:1;display:none;align-items:center;justify-content:center;flex-direction:column;gap:8px;}
#view-empty.show{display:flex;}
.empty-mark{font-size:48px;font-weight:700;color:var(--border2);letter-spacing:-2px;}
.empty-txt{font-size:9px;letter-spacing:2px;color:var(--g600);text-transform:uppercase;}

.cw-name{width:155px;}.cw-status{width:82px;}.cw-plan{width:100px;}
.cw-joined{width:105px;}.cw-subend{width:108px;}.cw-last{width:138px;}
.cw-paid{width:92px;}.cw-units{width:88px;}.cw-logged{width:85px;}
.cw-wr{width:70px;}.cw-sport{width:68px;}.cw-contract{width:95px;}
.cw-email{width:195px;}.cw-id{width:90px;}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-brand">EDGE <span>TERMINAL</span><span style="color:var(--g600);font-weight:400;font-size:10px;letter-spacing:2px;margin-left:12px;">// ADMIN</span></div>
  <div class="nav-center" style="flex:1;padding:0 24px;">
    <input type="text" id="search-input" placeholder="> search users..." oninput="renderSidebar()" style="width:100%;max-width:340px;background:var(--border);border:1px solid var(--border2);color:#fff;font-family:var(--mono);font-size:10px;padding:7px 12px;outline:none;letter-spacing:0.5px;">
  </div>
  <div class="nav-right">
    <div class="nav-stat">
      <div class="nav-stat-val" id="nav-active">—</div>
      <div class="nav-stat-label">Active Subs</div>
    </div>
    <div class="nav-stat">
      <div class="nav-stat-val" id="nav-mrr">—</div>
      <div class="nav-stat-label">MRR</div>
    </div>
    <div class="nav-dot"></div>
    <div style="font-size:8px;letter-spacing:1.5px;color:var(--green);text-transform:uppercase;">LIVE</div>
  </div>
</nav>

<div class="app">
  <div class="sidebar">
    <div style="display:flex;flex-direction:column;">
      <div class="nav-tab active" id="tab-all" onclick="switchView('all')" style="height:44px;border-right:none;border-left:none;border-bottom:1px solid var(--border);padding:0 16px;width:100%;justify-content:flex-start;">ALL USERS</div>
      <div class="nav-tab create-tab" id="tab-create" onclick="switchView('create')" style="height:44px;border-right:none;border-left:none;border-bottom:1px solid var(--border);padding:0 16px;width:100%;justify-content:flex-start;">+ CREATE USER</div>
      <div class="nav-tab" id="tab-ambassador" onclick="switchView('ambassador')" style="height:44px;border-right:none;border-left:none;border-bottom:1px solid var(--border);padding:0 16px;width:100%;justify-content:flex-start;">AMBASSADOR</div>
    </div>
  </div>

  <div class="main">

    <!-- ALL VIEW -->
    <div id="view-all" style="display:flex;">
      <div class="tbl-topbar">
        <div>
          <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--g600);">// OVERVIEW TABLE · ALL USERS</div>
          <div style="font-size:14px;font-weight:700;color:#fff;margin-top:2px;">User Database</div>
        </div>
        <div class="tbl-filters">
          <button class="filter-btn active" onclick="setFilter('all',this)">ALL</button>
          <button class="filter-btn" onclick="setFilter('active',this)">ACTIVE</button>
          <button class="filter-btn" onclick="setFilter('inactive',this)">INACTIVE</button>
          <button class="filter-btn" onclick="setFilter('pending',this)">PENDING CONTRACT</button>
        </div>
      </div>
      <div class="tbl-wrap">
        <table class="dt">
          <thead><tr>
            <th class="cw-name" onclick="sortBy('name')">NAME <span id="arr-name">▼</span></th>
            <th class="cw-status" onclick="sortBy('active')">STATUS <span id="arr-active"></span></th>
            <th class="cw-plan" onclick="sortBy('planShort')">PLAN <span id="arr-planShort"></span></th>
            <th class="cw-joined" onclick="sortBy('joinedTs')">JOINED <span id="arr-joinedTs"></span></th>
            <th class="cw-subend" onclick="sortBy('subEndTs')">SUB ENDS <span id="arr-subEndTs"></span></th>
            <th class="cw-last" onclick="sortBy('lastSignTs')">LAST SIGN IN <span id="arr-lastSignTs"></span></th>
            <th class="cw-paid" onclick="sortBy('paidNum')">TOTAL PAID <span id="arr-paidNum"></span></th>
            <th class="cw-units" onclick="sortBy('unitsNum')">UNITS UP <span id="arr-unitsNum"></span></th>
            <th class="cw-logged" onclick="sortBy('loggedNum')">UNITS LOG <span id="arr-loggedNum"></span></th>
            <th class="cw-wr" onclick="sortBy('winrateNum')">WIN % <span id="arr-winrateNum"></span></th>
            <th class="cw-sport" onclick="sortBy('sport')">SPORT <span id="arr-sport"></span></th>
            <th class="cw-contract" onclick="sortBy('contractShort')">CONTRACT <span id="arr-contractShort"></span></th>
            <th class="cw-email">EMAIL</th>
            <th class="cw-id">USER ID</th>
          </tr></thead>
          <tbody id="table-body"></tbody>
        </table>
      </div>
      <div class="tbl-footer">
        <div class="sum-cell"><div class="sum-label">TOTAL USERS</div><div class="sum-val" id="sum-total">—</div></div>
        <div class="sum-cell"><div class="sum-label">ACTIVE</div><div class="sum-val grn" id="sum-active">—</div></div>
        <div class="sum-cell"><div class="sum-label">TOTAL PAID IN</div><div class="sum-val grn" id="sum-paid">—</div></div>
        <div class="sum-cell"><div class="sum-label">AVG WIN RATE</div><div class="sum-val" id="sum-wr">—</div></div>
        <div class="sum-cell"><div class="sum-label">TOTAL UNITS UP</div><div class="sum-val grn" id="sum-units">—</div></div>
        <div class="sum-cell"><div class="sum-label">MRR (EST.)</div><div class="sum-val grn" id="sum-mrr">—</div></div>
      </div>
    </div>

    <!-- USER DETAIL VIEW -->
    <div id="view-user" style="display:none;flex:1;overflow-y:auto;">
      <div class="detail-topbar">
        <div>
          <div class="crumb" onclick="switchView('all')">← ALL USERS</div>
          <div class="detail-name" id="d-name">—</div>
        </div>
        <div class="badges">
          <div class="dbadge" id="d-sub-badge">—</div>
          <div class="dbadge neutral" id="d-sport-badge">—</div>
          <div class="dbadge neutral" id="d-plan-badge">—</div>
        </div>
      </div>

      <div class="metrics-strip">
        <div class="mc"><div class="mc-label">UNITS UP</div><div class="mc-val grn" id="m-units">—</div><div class="mc-sub" id="m-units-sub">—</div></div>
        <div class="mc"><div class="mc-label">UNITS LOGGED</div><div class="mc-val" id="m-logged">—</div><div class="mc-sub" id="m-logged-sub">—</div></div>
        <div class="mc"><div class="mc-label">WIN RATE</div><div class="mc-val" id="m-winrate">—</div><div class="mc-sub" id="m-wr-sub">—</div></div>
        <div class="mc"><div class="mc-label">TOTAL PAID</div><div class="mc-val grn" id="m-paid">—</div><div class="mc-sub" id="m-paid-sub">—</div></div>
        <div class="mc"><div class="mc-label">PICKS TAKEN</div><div class="mc-val" id="m-picks">—</div><div class="mc-sub">Total picks logged</div></div>
      </div>

      <div class="two-col">
        <div class="panel">
          <div class="panel-hdr">// ACCOUNT DETAILS</div>
